# New Volcengine console API key.
# Do not commit your real key.
DOUBAO_ASR_API_KEY=

# Audio upload defaults. mp3 keeps local uploads small for the 100MB flash limit.
DOUBAO_ASR_UPLOAD_FORMAT=mp3
DOUBAO_ASR_AUDIO_BITRATE=48k
DOUBAO_ASR_LANGUAGE=zh-CN
DOUBAO_ASR_SAMPLE_RATE=16000
DOUBAO_ASR_CHANNELS=1

# Recognition and subtitle defaults.
DOUBAO_ASR_ENABLE_ITN=true
DOUBAO_ASR_ENABLE_PUNC=true
DOUBAO_ASR_ENABLE_DDC=false
DOUBAO_ASR_ENABLE_SPEAKER_INFO=false
DOUBAO_ASR_ENABLE_CHANNEL_SPLIT=false
DOUBAO_ASR_VAD_SEGMENT=false
DOUBAO_ASR_CAPTION_MIN_CHARS=10
DOUBAO_ASR_CAPTION_MAX_CHARS=15
DOUBAO_ASR_CAPTION_PAUSE_SECONDS=0.45
DOUBAO_ASR_MAX_UPLOAD_MB=100
